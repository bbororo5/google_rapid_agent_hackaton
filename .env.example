# LaunchPilot shared env (repo root). Copy to .env and fill in real values.
# .env is gitignored; THIS file (.env.example) is committed — never put real keys here.

# --- LLM (Google ADK / Gemini) ---
# Pick ONE auth path:
#  A) AI Studio: set GEMINI_API_KEY (starts with AIza...) from aistudio.google.com/apikey
#  B) Vertex AI (Agent Platform): leave GEMINI_API_KEY blank, set the GOOGLE_* vars
#     below, and run `gcloud auth application-default login` (ADC, no key needed).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Vertex AI path (option B):
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# --- Elastic Cloud — Java backend (contract 03 writes) ---
# Java reads these from the process env (compose injects them via env_file).
ELASTIC_URL=https://your-cluster.es.region.gcp.elastic.cloud:443
ELASTIC_API_KEY=your-encoded-api-key

# --- Evidence (Elastic via MCP) — Python agent (contract 04, method B) ---
# ELASTIC_USE_MCP=true routes evidence through the Elasticsearch MCP server,
# spawned via npx and authed with ELASTIC_URL/ELASTIC_API_KEY. Requires node/npx.
# Falls back to direct ES, then seeded BTS demo data. Empty = direct ES / seed.
ELASTIC_USE_MCP=
# MCP server npx package. Default has esql_query (server-side aggregation). The
# official @elastic/mcp-server-elasticsearch 0.3.1 has search only (no ES|QL).
ELASTIC_MCP_PACKAGE=@tocharianou/elasticsearch-mcp
ELASTIC_MCP_URL=
ELASTIC_MCP_TRANSPORT=streamable_http

# --- Java -> Python base URL (compose uses the service name, not localhost) ---
AGENT_SERVICE_URL=http://agent:8000

# --- Reflection tracing (Phoenix). Optional, export-only, won't break the run. ---
# observability.py targets Phoenix. For Arize AX (cloud) the wiring differs.
# Set the API key to turn tracing ON; empty = no-op (domain spans become no-ops).
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_API_KEY=
PHOENIX_PROJECT_NAME=launchpilot-agent
# PHOENIX_USE_MCP=true enables the reflection READ side (Phoenix MCP get-spans):
# an advisory past-failure summary at session start. Requires node/npx. Off = no-op.
PHOENIX_USE_MCP=

# --- Server ---
PORT=8000

# --- docker compose host ports (override if they clash with local dev) ---
AGENT_HOST_PORT=8000
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=3000

# --- Signal thresholds (UNVERIFIED placeholders) ---
SIGNAL_THRESHOLD_HIGH=2.0
SIGNAL_THRESHOLD_LOW=1.3

# --- Failure policy ---
TOOL_MAX_RETRIES=2
BACKTRACK_LIMIT=3
