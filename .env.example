# LaunchPilot local env. Copy to .env and fill real secrets.
# .env is gitignored; never commit real keys here.

# --- Gemini (AI Studio) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_THINKING_LEVEL=minimal
LLM_CALL_TIMEOUT_S=180

# --- Local Elasticsearch (Docker Compose) ---
# Host access uses localhost. Compose overrides container-to-container access to
# http://elasticsearch:9200 with an empty API key.
ELASTIC_URL=http://localhost:9200
ELASTIC_API_KEY=

# --- Java -> Python base URL ---
AGENT_SERVICE_URL=http://agent:8000

# --- Phoenix / Arize (external, evaluation and agent traces) ---
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_API_KEY=
PHOENIX_PROJECT_NAME=launchpilot-agent
PHOENIX_USE_MCP=

# --- Grafana Cloud OTLP via local Alloy ---
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-northeast-0.grafana.net/otlp
GRAFANA_CLOUD_OTLP_INSTANCE_ID=
GRAFANA_CLOUD_ACCESS_TOKEN=

# --- Server / host ports ---
PORT=8000
AGENT_HOST_PORT=8000
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=3000
ELASTIC_HOST_PORT=9200
ALLOY_HOST_PORT=12345
OTLP_GRPC_HOST_PORT=4317
OTLP_HTTP_HOST_PORT=4318

# --- Runtime tuning ---
SIGNAL_THRESHOLD_HIGH=2.0
SIGNAL_THRESHOLD_LOW=1.3
TOOL_MAX_RETRIES=2
BACKTRACK_LIMIT=3
