# --- LLM (Google ADK / Gemini) ---
# If GEMINI_API_KEY is unset, the service runs in STUB mode (deterministic
# outputs, no LLM call) so the golden path is testable offline.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Evidence source (Elastic via MCP) ---
# If ELASTIC_MCP_URL is unset, evidence tools serve seeded stub data from
# seed/ so the pipeline runs without a live Elastic cluster.
ELASTIC_MCP_URL=
# transport: streamable_http | sse | stdio
ELASTIC_MCP_TRANSPORT=streamable_http

# --- Reflection (Arize/Phoenix) ---
# Tracing export (write). Reflection read tools are stubbed for the golden path.
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT_NAME=launchpilot-agent

# --- Server ---
PORT=8000

# --- Signal thresholds (UNVERIFIED placeholders, reverse-engineered from demo) ---
SIGNAL_THRESHOLD_HIGH=2.0
SIGNAL_THRESHOLD_LOW=1.3

# --- Failure policy (agent-tool-spec §4/§6) ---
TOOL_MAX_RETRIES=2
BACKTRACK_LIMIT=3
