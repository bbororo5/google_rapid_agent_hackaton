# --- LLM (Google ADK) ---
# Two auth paths. Pick ONE. If neither is configured, the service runs in STUB
# mode (deterministic outputs, no LLM call) so the golden path is testable offline.
#
# Path A (recommended): Vertex AI via ADC (Application Default Credentials).
#   No API key in the repo. ADK auths through ADC automatically.
#   Set up ADC once on your machine:  gcloud auth application-default login
#   (or point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON).
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_GENAI_USE_ENTERPRISE=TRUE
GOOGLE_CLOUD_PROJECT=rapid-agent-hackacthon
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-3.5-flash
GEMINI_THINKING_LEVEL=minimal
#
# Path B (alternative): AI Studio API key. Leave Vertex vars blank and set:
# GEMINI_API_KEY=

# --- Evidence source (Elastic via MCP) ---
# If ELASTIC_MCP_URL is unset, evidence tools serve seeded stub data from
# seed/ so the pipeline runs without a live Elastic cluster.
ELASTIC_MCP_URL=
# transport: streamable_http | sse | stdio
ELASTIC_MCP_TRANSPORT=streamable_http

# --- Reflection (Arize/Phoenix) ---
# Tracing export (write). Reflection read tools are stubbed for the golden path.
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT_NAME=launchpilot-agent

# --- Server ---
PORT=8000

# --- Signal thresholds (UNVERIFIED placeholders, reverse-engineered from demo) ---
SIGNAL_THRESHOLD_HIGH=2.0
SIGNAL_THRESHOLD_LOW=1.3

# --- Failure policy (agent-tool-spec §4/§6) ---
TOOL_MAX_RETRIES=2
BACKTRACK_LIMIT=3
