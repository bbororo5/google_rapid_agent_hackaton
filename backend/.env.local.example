# 복사: .env.local.example -> .env.local 후 값 채우기. .env.local은 gitignore됨 (커밋 안 됨).
# 로더로 세션에 주입 후 gradle 실행. Spring/Gradle은 이 파일을 자동으로 읽지 않는다.
ELASTIC_URL=https://your-cluster.es.region.gcp.elastic.cloud:443
ELASTIC_API_KEY=your-encoded-api-key
# Python 인프라 (아직 없으면 생략 - e2e는 WireMock이 대체)
AGENT_SERVICE_URL=http://localhost:8000
