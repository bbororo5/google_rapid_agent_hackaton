{
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "test": "npm run test:contracts && npm run test:scenarios",
    "test:contracts": "node tools/verify-contracts.mjs",
    "test:scenarios": "node tools/verify-scenarios.mjs",
    "frontend:dev": "npm run dev -w apps/frontend",
    "frontend:build": "npm run build -w apps/frontend",
    "frontend:lint": "npm run lint -w apps/frontend",
    "test:e2e": "npm run test:e2e:real",
    "test:e2e:real": "node tools/e2e-preflight.mjs && playwright test e2e/real-round-based-workflow.spec.ts",
    "test:e2e:memory": "node tools/e2e-preflight.mjs && playwright test e2e/memory-continuity.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:list": "playwright test --list"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.9.0"
  }
}
